# 本地运行示例（不要提交真实 .env）
WIKI_API=https://example.org/w/api.php
WIKI_USER=YourTargetUsername
DISPLAY_NAME=
EXCLUDED_NAMESPACES=
CHART_SORT_MODE=namespace
CHART_SERIES_TYPE=bar
MULTI_SERIES_RENDER_MODE=stacked
ACCOUNT_REG_MARKER_ENABLED=false
ACCOUNT_REG_MARKER_OUT_OF_RANGE=clamp_to_first
BOT_USERNAME=MainAccount@BotName
BOT_PASSWORD=YourBotPassword
WIKI_PAGE=User:YourRealWikiUser/ContributionsChart
EDIT_TAG_CANDIDATES=bot, Bot

# 自定义 User-Agent（建议改成你的联系方式）
USER_AGENT=WikiChartBot/1.0 (https://github.com/your-org/your-repo; your-noreply-email@users.noreply.github.com) requests/2.x
